{
  "name": "opencode-session-memory-sidebar-installer",
  "version": "0.1.7",
  "bin": {
    "opencode-session-memory-sidebar-installer": "./bin/install.mjs"
  },
  "description": "Clone-free installer for the Opencode RAM optimizer tool",
  "files": [
    "bin",
    "dist",
    "README.md"
  ],
  "keywords": [
    "opencode",
    "tool",
    "ram",
    "cleanup",
    "subagent"
  ],
  "license": "MIT",
  "scripts": {
    "install-local": "node ./bin/install.mjs",
    "uninstall-local": "node ./bin/uninstall.mjs",
    "build:standalone": "bunx esbuild ./bin/standalone.mjs --bundle --platform=node --format=cjs --outfile=./dist/CancerBroker.cjs"
  },
  "type": "module"
}
